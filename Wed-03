<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Programm for Wednesday 03-June-2026</title>
  <link rel="stylesheet" href="./styles.css" />
  <style>
    body{font-family:Inter, system-ui, Arial, sans-serif;padding:20px;background:#fff;color:#222}
    .container{max-width:980px;margin:0 auto}
    h1{font-size:1.25rem;margin:0 0 12px}
    .back{margin-bottom:12px;display:inline-block}
    table.timeline{width:100%;border-collapse:collapse}
    table.timeline td{border:1px solid #e0e0e0;padding:10px;vertical-align:top}
    table.timeline td.time{width:110px;white-space:nowrap;font-weight:600}
    table.timeline td.event{}
    @media(max-width:600px){ table.timeline td.time{width:90px} }
  </style>
</head>
<body>
  <div class="container">
    <a class="back" href="./index.html">← Back</a>
    <h1>Programm for Wednesday 03-June-2026</h1>

    <table class="timeline" role="presentation" aria-label="Wednesday program">
      <tbody>
        <tr>
          <td class="time">18:00</td>
          <td class="event">Restaurant tbd</td>
        </tr>
      </tbody>
    </table>
  </div>

  <script src="./app.js"></script>
</body>
</html>
